<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Section 3 — 神祇图鉴</title>

  <!-- Google Fonts — load first -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cinzel+Decorative:wght@400;700&family=Noto+Serif+SC:wght@300;400;500;700&display=swap" rel="stylesheet">

  <style>
    /* ============================================================
       CSS CUSTOM PROPERTIES — greek-myth-design dark mode
       ============================================================ */
    :root {
      --background:      #0d0b0e;
      --surface0:        #0d0b0e;
      --surface1:        #1a1613;
      --surface2:        #231e1a;
      --surface3:        #2e2722;
      --border:          #3a3028;
      --border-visible:  #5a4830;
      --border-gold:     #c9a84c;
      --text1:           #f0ead8;
      --text2:           #c9a84c;
      --text3:           #a8906a;
      --text4:           #6b5744;
      --accent:          #c9a84c;
      --accent-dim:      #8a6d28;
      --accent-glow:     rgba(201, 168, 76, 0.18);
      --accent-glow-md:  rgba(201, 168, 76, 0.08);

      --font-display:  'Cinzel Decorative', 'Cinzel', Georgia, serif;
      --font-heading:  'Cinzel', Georgia, 'Times New Roman', serif;
      --font-body:     'Noto Serif SC', Georgia, '宋体', SimSun, serif;

      --easing-ritual:  cubic-bezier(0.22, 1, 0.36, 1);
      --duration-micro:    200ms;
      --duration-standard: 350ms;
    }

    /* ============================================================
       RESET & BASE
       ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      background: var(--background);
      min-height: 100vh;
    }

    body {
      background-color: var(--background);
      background-image:
        /* subtle dot grid — aged paper texture */
        radial-gradient(circle, rgba(201,168,76,0.06) 1px, transparent 1px),
        radial-gradient(circle, rgba(240,234,216,0.025) 1px, transparent 1px);
      background-size: 28px 28px, 7px 7px;
      background-position: 0 0, 3.5px 3.5px;
      color: var(--text1);
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 2.0;
      letter-spacing: 0.05em;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ============================================================
       SECTION WRAPPER
       ============================================================ */
    .section-deities {
      width: 100%;
      padding: 72px 64px 80px;
      position: relative;
      overflow: hidden;
    }

    /* Ambient vignette at section edges */
    .section-deities::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 50% 0%, rgba(201,168,76,0.04) 0%, transparent 70%),
        radial-gradient(ellipse 100% 30% at 0% 50%, rgba(201,168,76,0.025) 0%, transparent 60%),
        radial-gradient(ellipse 100% 30% at 100% 50%, rgba(201,168,76,0.025) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    .section-inner {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* ============================================================
       SECTION HEADER
       ============================================================ */
    .section-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .micro-label {
      display: inline-block;
      font-family: var(--font-heading);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.45em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 20px;
      opacity: 0.85;
    }

    .section-title {
      font-family: 'Noto Serif SC', 'Georgia', '宋体', serif;
      font-size: 42px;
      font-weight: 300;
      line-height: 1.25;
      letter-spacing: 0.18em;
      color: var(--text1);
      margin-bottom: 28px;
    }

    /* Gold ornamental divider */
    .ornament-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 0 auto;
      width: 320px;
    }

    .ornament-divider .line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0.6;
    }

    .ornament-divider .diamond {
      font-family: var(--font-heading);
      font-size: 8px;
      color: var(--accent);
      letter-spacing: 0;
      opacity: 0.9;
    }

    /* ============================================================
       BENTO DEITY GRID — 2 rows × 4 columns, gapless
       ============================================================ */
    .deity-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, auto);
      gap: 0;
      border: 1px solid var(--border-gold);
      opacity: 0.85;
      margin-bottom: 36px;
    }

    /* Individual deity card */
    .deity-card {
      background: var(--surface1);
      border: 1px solid var(--border-gold);
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition:
        border-color var(--duration-micro) var(--easing-ritual),
        background var(--duration-micro) var(--easing-ritual);
    }

    /* Remove double borders between cells — use negative margin or outline */
    .deity-card {
      margin: -1px 0 0 -1px;
    }
    .deity-grid {
      padding: 1px 0 0 1px;
    }

    .deity-card:hover {
      border-color: var(--accent);
      background: #201c18;
      z-index: 2;
    }

    /* Portrait area — square cropped */
    .deity-portrait {
      width: 100%;
      aspect-ratio: 1 / 1;
      position: relative;
      overflow: hidden;
    }

    .deity-portrait svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Inner vignette overlay on portrait */
    .deity-portrait::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 45%, rgba(13,11,14,0.55) 100%);
      pointer-events: none;
    }

    /* Bottom strip: name + descriptor */
    .deity-label {
      padding: 10px 12px 11px;
      border-top: 1px solid var(--border-gold);
      background: linear-gradient(180deg, #1a1613 0%, #141210 100%);
    }

    .deity-name {
      font-family: var(--font-heading);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.2em;
      color: var(--accent);
      display: block;
      margin-bottom: 2px;
    }

    .deity-descriptor {
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.08em;
      color: var(--text3);
      display: block;
      line-height: 1.4;
    }

    /* ============================================================
       HIGHLIGHTED CARD — Athena (position 2 in row 1, index 1)
       ============================================================ */
    .deity-card.featured {
      background: #1f1b16;
      border-color: var(--accent);
      z-index: 3;
    }

    .deity-card.featured::before {
      content: '';
      position: absolute;
      inset: -1px;
      border: 1px solid var(--accent);
      box-shadow:
        0 0 0 1px rgba(201,168,76,0.15),
        inset 0 0 20px rgba(201,168,76,0.04);
      pointer-events: none;
      z-index: 4;
    }

    /* Outer glow for featured card — soft luminous halo */
    .deity-card.featured::after {
      content: '';
      position: absolute;
      inset: -3px;
      border: 1px solid rgba(201,168,76,0.4);
      pointer-events: none;
      z-index: 3;
      /* inset box glow to simulate card emission */
      box-shadow: 0 0 0 2px rgba(201,168,76,0.12);
    }

    .deity-card.featured .deity-portrait::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 30%, rgba(201,168,76,0.08) 0%, transparent 70%);
      pointer-events: none;
      z-index: 1;
    }

    .deity-card.featured .deity-label {
      background: linear-gradient(180deg, #241f18 0%, #1a1512 100%);
    }

    .deity-card.featured .deity-name {
      color: #e8c060;
    }

    /* ============================================================
       CTA CAPTION
       ============================================================ */
    .cta-caption {
      text-align: center;
    }

    .cta-link {
      font-family: var(--font-heading);
      font-size: 12px;
      font-weight: 400;
      letter-spacing: 0.3em;
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid rgba(201,168,76,0.5);
      padding-bottom: 2px;
      transition: border-color var(--duration-micro) ease-out,
                  color var(--duration-micro) ease-out;
    }

    .cta-link:hover {
      color: #e8c060;
      border-bottom-color: var(--accent);
    }

    /* ============================================================
       SVG DEITY PORTRAITS — oil-painting style, inline
       Each deity has:
       - Moody layered color backdrop
       - Characteristic visual elements (symbols, attributes)
       - Painted-feel blended brushstroke shapes
       - Consistent warm dark palette
       ============================================================ */
  </style>
</head>
<body>

<section class="section-deities">
  <div class="section-inner">

    <!-- HEADER -->
    <header class="section-header">
      <p style="font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.5em;color:rgba(201,168,76,0.4);text-transform:uppercase;margin-bottom:10px;">✦ &nbsp; III &nbsp; ✦</p>
      <span class="micro-label">DEITY ARCHETYPES</span>

      <h2 class="section-title">八位神祇，等待被召唤</h2>

      <div class="ornament-divider">
        <span class="line"></span>
        <span class="diamond">✦</span>
        <span class="diamond" style="font-size:6px; opacity:0.5;">◆</span>
        <span class="diamond">✦</span>
        <span class="line"></span>
      </div>
    </header>

    <!-- DEITY BENTO GRID -->
    <div class="deity-grid">

      <!-- 1. ZEUS — lightning, throne -->
      <div class="deity-card">
        <div class="deity-portrait">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="bg-zeus" cx="50%" cy="35%" r="65%">
                <stop offset="0%" stop-color="#2a1f0a"/>
                <stop offset="60%" stop-color="#1a1208"/>
                <stop offset="100%" stop-color="#0d0a06"/>
              </radialGradient>
              <radialGradient id="sky-zeus" cx="50%" cy="20%" r="50%">
                <stop offset="0%" stop-color="#4a3a18" stop-opacity="0.7"/>
                <stop offset="100%" stop-color="transparent"/>
              </radialGradient>
              <filter id="glow-zeus">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feComposite in="SourceGraphic" in2="blur" operator="over"/>
              </filter>
            </defs>
            <!-- Sky background -->
            <rect width="200" height="200" fill="url(#bg-zeus)"/>
            <ellipse cx="100" cy="40" rx="90" ry="70" fill="url(#sky-zeus)"/>
            <!-- Storm clouds – brushstroke shapes -->
            <ellipse cx="60" cy="55" rx="45" ry="22" fill="#2a2010" opacity="0.8"/>
            <ellipse cx="140" cy="45" rx="50" ry="18" fill="#241c0c" opacity="0.7"/>
            <ellipse cx="100" cy="65" rx="60" ry="25" fill="#1e1808" opacity="0.9"/>
            <!-- Throne suggestion — architectural columns hinted -->
            <rect x="30" y="110" width="12" height="70" fill="#3a2c10" opacity="0.5"/>
            <rect x="158" y="120" width="10" height="60" fill="#3a2c10" opacity="0.4"/>
            <!-- Figure silhouette — Zeus seated, robed -->
            <ellipse cx="100" cy="145" rx="38" ry="45" fill="#241c0a" opacity="0.95"/>
            <ellipse cx="100" cy="95" rx="26" ry="30" fill="#2e2410" opacity="0.9"/>
            <!-- Head -->
            <ellipse cx="100" cy="72" rx="18" ry="20" fill="#4a3820" opacity="0.85"/>
            <!-- White beard suggestion -->
            <ellipse cx="100" cy="86" rx="12" ry="8" fill="#c8b890" opacity="0.2"/>
            <!-- Zeus crown/laurel hint -->
            <ellipse cx="100" cy="60" rx="18" ry="5" fill="#c9a84c" opacity="0.15"/>
            <!-- LIGHTNING BOLT — central iconic element -->
            <g filter="url(#glow-zeus)" opacity="0.9">
              <polygon points="108,38 96,80 104,80 90,130 118,75 108,75 120,38" fill="#f0d878" opacity="0.85"/>
              <polygon points="108,38 96,80 104,80 90,130 118,75 108,75 120,38" fill="#c9a84c" opacity="0.4"/>
            </g>
            <!-- Secondary lightning streaks -->
            <line x1="145" y1="50" x2="130" y2="90" stroke="#c9a84c" stroke-width="1" opacity="0.3"/>
            <line x1="55" y1="60" x2="72" y2="95" stroke="#c9a84c" stroke-width="0.8" opacity="0.25"/>
            <!-- Ground shadow -->
            <ellipse cx="100" cy="192" rx="55" ry="8" fill="#0a0805" opacity="0.8"/>
            <!-- Atmospheric glow behind figure -->
            <radialGradient id="aura-zeus" cx="50%" cy="60%" r="35%">
              <stop offset="0%" stop-color="#c9a84c" stop-opacity="0.08"/>
              <stop offset="100%" stop-color="transparent"/>
            </radialGradient>
            <ellipse cx="100" cy="110" rx="55" ry="60" fill="url(#aura-zeus)"/>
          </svg>
        </div>
        <div class="deity-label">
          <span class="deity-name">ZEUS</span>
          <span class="deity-descriptor">宙斯 · 权威与秩序</span>
        </div>
      </div>

      <!-- 2. ATHENA — owl, helmet — FEATURED -->
      <div class="deity-card featured">
        <div class="deity-portrait">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="bg-athena" cx="50%" cy="40%" r="60%">
                <stop offset="0%" stop-color="#1a1f14"/>
                <stop offset="55%" stop-color="#0f1408"/>
                <stop offset="100%" stop-color="#080c05"/>
              </radialGradient>
              <radialGradient id="aura-athena" cx="50%" cy="40%" r="40%">
                <stop offset="0%" stop-color="#c9a84c" stop-opacity="0.14"/>
                <stop offset="100%" stop-color="transparent"/>
              </radialGradient>
              <filter id="soft-athena">
                <feGaussianBlur stdDeviation="1.5"/>
              </filter>
            </defs>
            <rect width="200" height="200" fill="url(#bg-athena)"/>
            <!-- Atmospheric haze -->
            <ellipse cx="100" cy="80" rx="85" ry="70" fill="url(#aura-athena)"/>
            <!-- Background architecture — Parthenon hint -->
            <rect x="10" y="140" width="8" height="45" fill="#2a301e" opacity="0.5"/>
            <rect x="28" y="148" width="6" height="37" fill="#2a301e" opacity="0.4"/>
            <rect x="166" y="142" width="8" height="43" fill="#2a301e" opacity="0.5"/>
            <!-- Robes — flowing painted shapes -->
            <ellipse cx="100" cy="155" rx="42" ry="48" fill="#1c2018" opacity="0.95"/>
            <path d="M65,130 Q50,170 60,200 L140,200 Q150,170 135,130 Q115,120 100,125 Q85,120 65,130Z" fill="#1e2218" opacity="0.9"/>
            <!-- Breastplate / aegis hint -->
            <ellipse cx="100" cy="115" rx="28" ry="22" fill="#2a3020" opacity="0.9"/>
            <ellipse cx="100" cy="115" rx="24" ry="18" fill="#242a1c" opacity="0.7"/>
            <!-- Medusa on aegis — tiny circular motif -->
            <circle cx="100" cy="113" r="6" fill="none" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
            <circle cx="100" cy="113" r="3" fill="#c9a84c" opacity="0.2"/>
            <!-- Neck -->
            <rect x="92" y="86" width="16" height="22" rx="4" fill="#3a3020" opacity="0.8"/>
            <!-- Head -->
            <ellipse cx="100" cy="76" rx="20" ry="22" fill="#3c3020" opacity="0.9"/>
            <!-- HELMET — Corinthian crested -->
            <path d="M82,68 Q82,48 100,44 Q118,48 118,68" fill="#c9a84c" opacity="0.7"/>
            <path d="M84,66 Q84,50 100,46 Q116,50 116,66" fill="#a87830" opacity="0.5"/>
            <!-- Helmet crest -->
            <path d="M95,44 Q100,28 105,32 Q110,20 115,28 Q112,38 105,40 Q108,30 103,38 Q100,28 97,38 Q92,35 95,44Z" fill="#c9a84c" opacity="0.6"/>
            <!-- Helmet visor/cheekguards -->
            <rect x="82" y="64" width="7" height="18" rx="1" fill="#a87830" opacity="0.6"/>
            <rect x="111" y="64" width="7" height="18" rx="1" fill="#a87830" opacity="0.6"/>
            <!-- Eyes — piercing grey-gold -->
            <ellipse cx="93" cy="74" rx="3.5" ry="3" fill="#c9a84c" opacity="0.55"/>
            <ellipse cx="107" cy="74" rx="3.5" ry="3" fill="#c9a84c" opacity="0.55"/>
            <ellipse cx="93" cy="74" rx="1.5" ry="1.5" fill="#1a1810" opacity="0.8"/>
            <ellipse cx="107" cy="74" rx="1.5" ry="1.5" fill="#1a1810" opacity="0.8"/>
            <!-- OWL — sitting right shoulder -->
            <ellipse cx="148" cy="122" rx="13" ry="16" fill="#1a1c14" opacity="0.9"/>
            <ellipse cx="148" cy="112" rx="10" ry="10" fill="#24261c" opacity="0.9"/>
            <!-- Owl eyes -->
            <circle cx="144" cy="110" r="3.5" fill="#c9a84c" opacity="0.7"/>
            <circle cx="152" cy="110" r="3.5" fill="#c9a84c" opacity="0.7"/>
            <circle cx="144" cy="110" r="1.5" fill="#0a0c08" opacity="0.9"/>
            <circle cx="152" cy="110" r="1.5" fill="#0a0c08" opacity="0.9"/>
            <!-- Owl beak -->
            <path d="M147,113 L149,117 L145,117Z" fill="#8a7030" opacity="0.7"/>
            <!-- Owl wings folded -->
            <path d="M137,118 Q130,128 135,140 Q140,132 148,130Z" fill="#1c1e14" opacity="0.8"/>
            <path d="M159,118 Q166,128 161,140 Q156,132 148,130Z" fill="#1c1e14" opacity="0.8"/>
            <!-- Spear hint — left side -->
            <rect x="50" y="30" width="2" height="170" fill="#c9a84c" opacity="0.3"/>
            <polygon points="51,30 47,42 55,42" fill="#c9a84c" opacity="0.4"/>
            <!-- Gold aura outline around featured figure -->
            <ellipse cx="100" cy="120" rx="55" ry="65" fill="none" stroke="#c9a84c" stroke-width="0.5" opacity="0.2"/>
          </svg>
        </div>
        <div class="deity-label">
          <span class="deity-name">ATHENA</span>
          <span class="deity-descriptor">雅典娜 · 智慧与战略</span>
        </div>
      </div>

      <!-- 3. APOLLO — sun, lyre -->
      <div class="deity-card">
        <div class="deity-portrait">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="bg-apollo" cx="50%" cy="30%" r="65%">
                <stop offset="0%" stop-color="#2a1e08"/>
                <stop offset="60%" stop-color="#1a1208"/>
                <stop offset="100%" stop-color="#0d0a06"/>
              </radialGradient>
              <radialGradient id="sun-apollo" cx="50%" cy="22%" r="30%">
                <stop offset="0%" stop-color="#f0c840" stop-opacity="0.5"/>
                <stop offset="50%" stop-color="#c9a84c" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="transparent"/>
              </radialGradient>
            </defs>
            <rect width="200" height="200" fill="url(#bg-apollo)"/>
            <ellipse cx="100" cy="50" rx="100" ry="80" fill="url(#sun-apollo)"/>
            <!-- Sun disc -->
            <circle cx="100" cy="38" r="18" fill="#f0c840" opacity="0.25"/>
            <circle cx="100" cy="38" r="12" fill="#f0c840" opacity="0.4"/>
            <circle cx="100" cy="38" r="7" fill="#f8e060" opacity="0.6"/>
            <!-- Sun rays -->
            <g stroke="#c9a84c" stroke-width="1" opacity="0.3">
              <line x1="100" y1="16" x2="100" y2="10"/>
              <line x1="116" y1="22" x2="120" y2="18"/>
              <line x1="122" y1="38" x2="128" y2="38"/>
              <line x1="116" y1="54" x2="120" y2="58"/>
              <line x1="84" y1="22" x2="80" y2="18"/>
              <line x1="78" y1="38" x2="72" y2="38"/>
              <line x1="84" y1="54" x2="80" y2="58"/>
            </g>
            <!-- Robes — white/cream painted -->
            <path d="M70,130 Q55,165 62,200 L138,200 Q145,165 130,130 Q115,118 100,122 Q85,118 70,130Z" fill="#3a3020" opacity="0.85"/>
            <!-- Torso -->
            <ellipse cx="100" cy="112" rx="26" ry="24" fill="#342a18" opacity="0.9"/>
            <!-- Neck -->
            <rect x="93" y="84" width="14" height="20" rx="3" fill="#3c3220" opacity="0.85"/>
            <!-- Head — idealized young Apollo -->
            <ellipse cx="100" cy="74" rx="19" ry="21" fill="#4a3c24" opacity="0.9"/>
            <!-- Laurel wreath -->
            <ellipse cx="100" cy="60" rx="19" ry="7" fill="none" stroke="#5a7a30" stroke-width="2" opacity="0.6"/>
            <ellipse cx="100" cy="60" rx="16" ry="5" fill="none" stroke="#4a6828" stroke-width="1.5" opacity="0.4"/>
            <!-- Leaf details -->
            <ellipse cx="82" cy="60" rx="5" ry="3" fill="#5a7a30" opacity="0.5" transform="rotate(-20,82,60)"/>
            <ellipse cx="90" cy="56" rx="5" ry="2.5" fill="#5a7a30" opacity="0.5" transform="rotate(-10,90,56)"/>
            <ellipse cx="110" cy="56" rx="5" ry="2.5" fill="#5a7a30" opacity="0.5" transform="rotate(10,110,56)"/>
            <ellipse cx="118" cy="60" rx="5" ry="3" fill="#5a7a30" opacity="0.5" transform="rotate(20,118,60)"/>
            <!-- LYRE — iconic attribute right side -->
            <g opacity="0.75">
              <!-- Lyre body -->
              <ellipse cx="148" cy="130" rx="14" ry="18" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
              <ellipse cx="148" cy="130" rx="8" ry="10" fill="#2a2010" opacity="0.8"/>
              <!-- Lyre arms -->
              <path d="M136,118 Q128,105 132,96" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
              <path d="M160,118 Q168,105 164,96" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
              <!-- Crossbar -->
              <line x1="132" y1="96" x2="164" y2="96" stroke="#c9a84c" stroke-width="1.5"/>
              <!-- Strings -->
