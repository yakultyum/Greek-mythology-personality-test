              <!-- Pomegranate crown top -->
              <path d="M143,115 Q148,110 153,115 Q150,112 148,114 Q146,112 143,115Z" fill="#8a2820" opacity="0.7"/>
              <path d="M144,114 Q148,108 152,114" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.4"/>
              <!-- Seeds visible through split -->
              <ellipse cx="144" cy="129" rx="3" ry="4" fill="#c94040" opacity="0.3"/>
              <ellipse cx="150" cy="127" rx="3" ry="4" fill="#c94040" opacity="0.3"/>
              <ellipse cx="148" cy="134" rx="3" ry="3" fill="#c94040" opacity="0.25"/>
            </g>
            <!-- Three-headed dog Cerberus silhouette — tiny, distant -->
            <ellipse cx="28" cy="178" rx="18" ry="10" fill="#0a0810" opacity="0.7"/>
            <circle cx="18" cy="170" r="5" fill="#0c0a14" opacity="0.7"/>
            <circle cx="28" cy="168" r="6" fill="#0c0a14" opacity="0.7"/>
            <circle cx="38" cy="170" r="5" fill="#0c0a14" opacity="0.7"/>
            <!-- Ground / Styx river glint -->
            <ellipse cx="100" cy="196" rx="55" ry="7" fill="#06040e" opacity="0.8"/>
            <path d="M30,194 Q65,188 100,193 Q135,188 170,194" fill="none" stroke="#c9a84c" stroke-width="0.5" opacity="0.12"/>
          </svg>
        </div>
        <div class="deity-label">
          <span class="deity-name">HADES</span>
          <span class="deity-descriptor">哈迪斯 · 冥府与永恒</span>
        </div>
      </div>

    </div><!-- end deity-grid -->

    <!-- CTA CAPTION -->
    <div class="cta-caption">
      <a href="#" class="cta-link">测出你的神祇 &nbsp;→</a>
    </div>

  </div><!-- end section-inner -->
</section>

</body>
</html>
